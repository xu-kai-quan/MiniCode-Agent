# Copy this file to .env and fill in your actual keys.
# .env is gitignored — never commit real keys.

# ===== Backend selection =====
# ollama (default, local, free) | minimax (cloud, paid, larger model)
MINICODE_BACKEND=ollama

# ===== Ollama (local) =====
# Defaults shown — uncomment to override
# MINICODE_OLLAMA_URL=http://localhost:11434
# MINICODE_MODEL=qwen2.5-coder:7b-instruct-q4_K_M

# ===== MiniMax (cloud) =====
# Get key from https://platform.minimaxi.com/
# Required when MINICODE_BACKEND=minimax
MINIMAX_API_KEY=

# Defaults shown — uncomment to override
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1
# MINIMAX_MODEL=MiniMax-M2.7

# ===== General =====
# MINICODE_TIMEOUT=300
# MINICODE_STREAM=1
